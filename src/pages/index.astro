---
import Layout from '../layouts/Layout.astro';
const cmsApiBaseUrl =
  import.meta.env.PUBLIC_CMS_API_BASE_URL || 'https://cms.tricode.studio/api/v1';
const tenantSlug = import.meta.env.PUBLIC_CMS_TENANT_SLUG || 'cuevas-automoviles';
const vehiclesSlug = import.meta.env.PUBLIC_CMS_VEHICLES_SLUG || '';
const legacyCatalogApiUrl = import.meta.env.PUBLIC_CATALOG_API_URL || '';
---
<Layout
  title="Cuevas Automóviles | Venta de Autos en Uruguay · Trinidad, Flores"
  description="Cuevas Automóviles, tu concesionaria de confianza en Trinidad, Flores, Uruguay. 36 años vendiendo autos nuevos y usados, bicicletas Trek, motores náuticos Honda y Mercury. ¡Visitanos!"
  navClass="transparent"
  activeLink="inicio"
>

<!-- ── HERO ────────────────────────────────────────────────── -->
<section class="hero" id="inicio">
  <div class="hero-bg-image"></div>
  <div class="hero-bg"></div>
  <div class="hero-bg-pattern"></div>

  <div class="hero-content">
    <div class="hero-text" style="animation:slideInLeft .7s ease both">
      <div class="hero-badge">
        <span class="dot"></span>
        Tu concesionaria en Trinidad, Flores
      </div>
      <h1 class="hero-title">
        Tu próximo auto<br>
        te espera en <span class="highlight">Cuevas Automóviles</span>
      </h1>
      <p class="hero-desc">
        Más de 36 años conectando a las familias uruguayas con el vehículo ideal.
        Autos nuevos y usados, bicicletas, náutica, financiación bancaria y lavadero.
      </p>
      <div class="hero-actions">
        <a href="/catalogo" class="btn btn-primary btn-lg">
          <i class="ph ph-car"></i> Ver catálogo
        </a>
        <a href="https://wa.me/59899364330?text=Hola!%20Quisiera%20consultar%20sobre%20sus%20vehículos" target="_blank" class="btn btn-outline btn-lg">
          <i class="ph ph-whatsapp-logo"></i> Consultar por WhatsApp
        </a>
      </div>
      <div class="hero-stats">
        <div class="stat">
          <div class="stat-number"><span data-target="36">0</span>+</div>
          <div class="stat-label">Años en el mercado</div>
        </div>
        <div class="stat">
          <div class="stat-number"><span data-target="5">0</span></div>
          <div class="stat-label">Marcas oficiales</div>
        </div>
        <div class="stat">
          <div class="stat-number"><span data-target="5">0</span></div>
          <div class="stat-label">Rubros de negocio</div>
        </div>
      </div>
    </div>

    <div class="hero-visual" style="display:flex; flex-direction:column; align-items:flex-end; gap:20px;">
      <div class="hero-card" style="width: 320px;">
        <div class="hero-card-icon"><i class="ph ph-car"></i></div>
        <div class="hero-card-title">Amplio Stock</div>
        <div class="hero-card-desc">Vehículos disponibles de todas las marcas líderes del mercado.</div>
      </div>
      <div class="hero-card" style="width: 320px;">
        <div class="hero-card-icon"><i class="ph ph-credit-card"></i></div>
        <div class="hero-card-title">Financiación Flexible</div>
        <div class="hero-card-desc">Planes disponibles a través de Santander, BBVA y Scotiabank, en pesos y dólares, con opciones de hasta 60 cuotas.</div>
      </div>
      <div class="hero-card" style="width: 320px;">
        <div class="hero-card-icon"><i class="ph ph-shield-check"></i></div>
        <div class="hero-card-title">Garantía Real</div>
        <div class="hero-card-desc">Todos nuestros vehículos cuentan con revisión técnica certificada.</div>
      </div>
    </div>
  </div>

</section>

<!-- ── FEATURED VEHICLES ──────────────────────────────────── -->
<section class="section" id="destacados">
  <div class="container">
    <div class="text-center animate-on-scroll">
      <div class="section-label">Vehículos Destacados</div>
      <h2 class="section-title">Nuestro stock</h2>
      <p class="section-sub">Selección de vehículos revisados y con garantía, listos para entrega inmediata.</p>
    </div>

    <div class="vehicles-grid" id="featuredGrid">
      <!-- Rendered by JS -->
    </div>

    <div class="text-center" style="margin-top:40px">
      <a href="/catalogo" class="btn btn-secondary btn-lg animate-on-scroll">
        Ver todo el catálogo →
      </a>
    </div>
  </div>
</section>

<!-- ── BRANDS ─────────────────────────────────────────────── -->
<section class="section brands-section">
  <div class="container">
    <div class="text-center animate-on-scroll">
      <div class="section-label">Marcas Oficiales</div>
      <h2 class="section-title">Representantes oficiales</h2>
      <p class="section-sub" style="color:rgba(255,255,255,.6)">Concesionario oficial de las mejores marcas. Vehículos nuevos y usados con respaldo de fábrica.</p>
    </div>
    <div class="brands-grid" style="margin-top:48px">
      <div id="homeBrandsGrid" style="grid-column:1/-1;color:rgba(255,255,255,.7);text-align:center;padding:20px 0">
        Cargando marcas...
      </div>
    </div>
  </div>
</section>

<!-- ── SERVICES ───────────────────────────────────────────── -->
<section class="section" id="servicios">
  <div class="container">
    <div class="animate-on-scroll">
      <div class="section-label">Servicios</div>
      <h2 class="section-title">Todo lo que necesitás</h2>
      <p class="section-sub">Más que una concesionaria — autos, bicicletas, náutica, financiación  Bancaria y mucho más. ¡36 años acompañando a las familias de Uruguay.!</p>
    </div>
    <div class="services-grid">
      <div class="service-card animate-on-scroll">
        <div class="service-icon"><i class="ph ph-credit-card"></i></div>
        <h3>Financiación Bancaria</h3>
        <p>Financiación ágil vía Santander, BBVA y Scotiabank. Planes en Pesos ($) y Dólares (U$S) hasta en 60 meses.</p>
        <a href="/servicios#financiacion" class="service-link">Ver opciones →</a>
      </div>
      <div class="service-card animate-on-scroll delay-1">
        <div class="service-icon"><i class="ph ph-arrows-clockwise"></i></div>
        <h3>Consignación</h3>
        <p>¿Querés vender tu auto? Lo recibimos en consignación. Sin estrés, sin complicaciones. Nosotros nos encargamos de la venta.</p>
        <a href="/contacto" class="service-link">Consultar →</a>
      </div>
      <div class="service-card animate-on-scroll delay-2">
        <div class="service-icon"><i class="ph ph-shower"></i></div>
        <h3>Lavadero</h3>
        <p>Servicio profesional de lavado completo, aspirado, encerado y detailing. Productos de primera calidad.</p>
        <a href="/servicios#lavadero" class="service-link">Ver más →</a>
      </div>
      <div class="service-card animate-on-scroll delay-3">
        <div class="service-icon"><i class="ph ph-bicycle"></i></div>
        <h3>Bicicletas Trek & Trink</h3>
        <p>Distribuidor oficial de bicicletas Trek y Trink, incluyendo modelos eléctricos. La mejor opción para moverse en Uruguay.</p>
        <a href="/servicios#bicicletas" class="service-link">Ver más →</a>
      </div>
      <div class="service-card animate-on-scroll delay-1">
        <div class="service-icon"><i class="ph ph-anchor"></i></div>
        <h3>Motores Náuticos</h3>
        <p>Motores Honda y Mercury para embarcaciones. Además, lanchas, canobotes, kayaks y embarcaciones Siux.</p>
        <a href="/servicios#nautica" class="service-link">Ver más →</a>
      </div>
      <div class="service-card animate-on-scroll delay-2">
        <div class="service-icon"><i class="ph ph-shield-check"></i></div>
        <h3>Seguros</h3>
        <p>Asesoramiento en seguros con Mapfre, Berkley, Sancor, SURA y Banco de Seguros. La mejor cobertura al mejor precio.</p>
        <a href="/contacto" class="service-link">Consultar →</a>
      </div>
    </div>
  </div>
</section>

<!-- ── CTA BANNER ─────────────────────────────────────────── -->
<section class="cta-banner">
  <div class="container">
    <div class="cta-inner">
      <div class="cta-text animate-on-scroll">
        <h2>¿Te podemos ayudar hoy?</h2>
        <p>Estamos en Inés Duran 1181, Trinidad. Más de 36 años de expriencia en el mercado te esperan. Contactanos sin compromiso y te atendemos al instante.</p>
      </div>
      <div class="cta-actions animate-on-scroll delay-1">
        <a href="https://wa.me/59899364330?text=Hola!%20Me%20interesa%20conocer%20más%20sobre%20sus%20vehículos" target="_blank" class="btn btn-primary btn-lg">
          <i class="ph ph-whatsapp-logo"></i> WhatsApp
        </a>
        <a href="tel:+59846343775" class="btn btn-outline btn-lg">
          <i class="ph ph-phone"></i> Llamar ahora
        </a>
      </div>
    </div>
  </div>
</section>

<!-- ── TESTIMONIALS ───────────────────────────────────────── -->
<section class="section testimonials-section">
  <div class="container">
    <div class="text-center animate-on-scroll">
      <div class="section-label">Testimonios</div>
      <h2 class="section-title">Lo que dicen nuestros clientes</h2>
      <p class="section-sub">Más de 500 familias uruguayas ya confían en Cuevas Automóviles.</p>
    </div>
    <div class="testimonials-grid">
      <div class="testimonial-card animate-on-scroll">
        <div class="testimonial-stars">★★★★★</div>
        <p class="testimonial-text">"Compré mi Toyota Hilux acá y la experiencia fue excelente. El asesor fue muy atento y la financiación fue más fácil de lo que esperaba. ¡Total recomendado!"</p>
        <div class="testimonial-author">
          <div class="testimonial-avatar">JG</div>
          <div>
            <div class="testimonial-name">Juan García</div>
            <div class="testimonial-location"><i class="ph ph-map-pin"></i> Trinidad, Flores</div>
          </div>
        </div>
      </div>
      <div class="testimonial-card animate-on-scroll delay-1">
        <div class="testimonial-stars">★★★★★</div>
        <p class="testimonial-text">"Excelente atención. Me ayudaron a encontrar el auto perfecto para mi familia dentro de mi presupuesto. El proceso fue rápido y transparente."</p>
        <div class="testimonial-author">
          <div class="testimonial-avatar">MR</div>
          <div>
            <div class="testimonial-name">María Rodríguez</div>
            <div class="testimonial-location"><i class="ph ph-map-pin"></i> Montevideo</div>
          </div>
        </div>
      </div>
      <div class="testimonial-card animate-on-scroll delay-2">
        <div class="testimonial-stars">★★★★★</div>
        <p class="testimonial-text">"Llevo dos autos comprados en Cuevas Automóviles y siempre quedé muy conforme. El taller también es muy bueno, seria y profesional."</p>
        <div class="testimonial-author">
          <div class="testimonial-avatar">CP</div>
          <div>
            <div class="testimonial-name">Carlos Pérez</div>
            <div class="testimonial-location"><i class="ph ph-map-pin"></i> Durazno</div>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>

<script define:vars={{ cmsApiBaseUrl, tenantSlug, vehiclesSlug, legacyCatalogApiUrl }}>
  window.__CUEVAS_CMS_API_BASE__ = cmsApiBaseUrl;
  window.__CUEVAS_TENANT_SLUG__ = tenantSlug;
  window.__CUEVAS_CMS_VEHICLES_SLUG__ = vehiclesSlug;
  window.__CUEVAS_CATALOG_API_URL__ = legacyCatalogApiUrl;
</script>
<script src="/js/inventory-api.js" is:inline></script>
<script src="/js/home-catalog.js" is:inline></script>

</Layout>
