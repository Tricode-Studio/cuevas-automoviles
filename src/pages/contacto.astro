---
import Layout from '../layouts/Layout.astro';
const cmsApiBaseUrl =
  import.meta.env.PUBLIC_CMS_API_BASE_URL || 'https://cms.tricode.studio/api/v1';
const tenantSlug = import.meta.env.PUBLIC_CMS_TENANT_SLUG || 'cuevas-automoviles';
---
<Layout
  title="Contacto | Cuevas Automóviles · Trinidad, Uruguay"
  description="Contactá a Cuevas Automóviles en Trinidad, Flores. Formulario, WhatsApp, teléfono y mapa de ubicación."
  navClass="solid"
  activeLink="contacto"
>

  <!-- HEADER -->
  <div class="contact-header">
    <div class="container" style="position:relative;z-index:1">
      <div class="breadcrumb">
        <a href="/">Inicio</a>
        <span class="sep">›</span>
        <span class="current">Contacto</span>
      </div>
      <h1>¿Cómo podemos ayudarte?</h1>
      <p>Estamos acá para responder tus preguntas y ayudarte a encontrar tu próximo vehículo. Contactanos por el canal
        que prefieras.</p>
    </div>
  </div>

  <!-- CONTACT MAIN -->
  <div class="container">
    <div class="contact-layout">

      <!-- CONTACT INFO -->
      <div class="contact-info">

        <div class="contact-info-card animate-on-scroll">
          <div class="contact-info-icon"><i class="ph ph-map-pin"></i></div>
          <div class="contact-info-content">
            <h4>Dirección</h4>
            <a href="https://www.google.com/maps?q=Inés+Duran+1181,+Trinidad,+Flores,+Uruguay" target="_blank" rel="noopener" style="color:inherit;text-decoration:none;display:block;transition:color .2s" onmouseover="this.style.color='var(--blue)'" onmouseout="this.style.color='inherit'">
              Inés Duran 1181<br>Trinidad, Flores, Uruguay<br>CP 8500
              <span style="display:inline-flex;align-items:center;gap:4px;font-size:.8rem;color:var(--blue);font-weight:600;margin-top:6px">Ver en Google Maps →</span>
            </a>
          </div>
        </div>

        <div class="contact-info-card animate-on-scroll delay-1">
          <div class="contact-info-icon"><i class="ph ph-phone"></i></div>
          <div class="contact-info-content">
            <h4>Teléfono</h4>
            <p><a href="tel:+59846343775">4634 3775</a> (Fijo)<br><a href="tel:+59899364330">099 364 330</a> (Cel)</p>
          </div>
        </div>

        <div class="contact-info-card animate-on-scroll delay-2">
          <div class="contact-info-icon"><i class="ph ph-whatsapp-logo"></i></div>
          <div class="contact-info-content">
            <h4>WhatsApp</h4>
            <p><a href="https://wa.me/59899364330" target="_blank">099 364 330</a><br>
              <a href="https://wa.me/59899364330" target="_blank" style="color:var(--blue);font-weight:600">Escribinos
                ahora →</a>
            </p>
          </div>
        </div>

        <div class="contact-info-card animate-on-scroll delay-3">
          <div class="contact-info-icon"><i class="ph ph-envelope"></i></div>
          <div class="contact-info-content">
            <h4>Email</h4>
            <p><a href="mailto:info@cuevaautos.com.uy">info@cuevaautos.com.uy</a></p>
          </div>
        </div>

        <div class="contact-info-card animate-on-scroll">
          <div class="contact-info-icon"><i class="ph ph-clock"></i></div>
          <div class="contact-info-content">
            <h4>Horarios de Atención</h4>
            <p>
              Lunes a Viernes: 8:30 – 18:30<br>
              Sábados: 9:00 – 13:00<br>
              Domingos: Cerrado
            </p>
          </div>
        </div>

        <!-- Social -->
        <div class="animate-on-scroll delay-1" style="padding:0 4px">
          <p style="font-size:.85rem;font-weight:600;color:var(--grey-dark);margin-bottom:12px">Seguinos en redes:</p>
          <div class="social-links">
            <a href="https://www.instagram.com/cuevasautomovilesuy/" target="_blank" class="social-link" title="Instagram"><i class="ph ph-instagram-logo"></i></a>
            <a href="https://wa.me/59899364330" class="social-link" title="WhatsApp" target="_blank"><i class="ph ph-whatsapp-logo"></i></a>
          </div>
        </div>

        <!-- Quick CTA -->
        <div class="animate-on-scroll delay-2">
          <a href="https://wa.me/59899364330?text=Hola!%20Vengo%20desde%20la%20web%20y%20quisiera%20consultar"
            target="_blank" class="btn btn-primary btn-lg" style="width:100%;justify-content:center">
            <i class="ph ph-whatsapp-logo"></i> Iniciar chat por WhatsApp
          </a>
        </div>

      </div>

      <!-- CONTACT FORM -->
      <div class="contact-form-card animate-on-scroll delay-1">
        <h2>Envianos un mensaje</h2>
        <p class="subtitle">Te respondemos en menos de 2 horas en horario laboral.</p>

        <form id="contactForm" novalidate>
          <div class="form-grid">
            <div class="form-group">
              <label for="firstName">Nombre *</label>
              <input type="text" id="firstName" name="firstName" required placeholder="Tu nombre">
            </div>
            <div class="form-group">
              <label for="lastName">Apellido *</label>
              <input type="text" id="lastName" name="lastName" required placeholder="Tu apellido">
            </div>
            <div class="form-group">
              <label for="phone">Teléfono *</label>
              <input type="tel" id="phone" name="phone" required placeholder="099 364 330">
            </div>
            <div class="form-group">
              <label for="email">Email</label>
              <input type="email" id="email" name="email" placeholder="tu@email.com">
            </div>
            <div class="form-group form-full">
              <label for="subject">Asunto *</label>
              <select id="subject" name="subject" required>
                <option value="">Seleccioná un tema…</option>
                <option value="compra">Compra de vehículo</option>
                <option value="financiacion">Financiación</option>
                <option value="permuta">Permuta / parte de pago</option>
                <option value="taller">Taller mecánico</option>
                <option value="lavadero">Lavadero</option>
                <option value="seguros">Seguros</option>
                <option value="otro">Otro</option>
              </select>
            </div>
            <div class="form-group form-full">
              <label for="vehicle">Vehículo de interés (opcional)</label>
              <input type="text" id="vehicle" name="vehicle" placeholder="Ej: Toyota Hilux 2022, Ford Ranger…">
            </div>
            <div class="form-group form-full">
              <label for="message">Mensaje *</label>
              <textarea id="message" name="message" required placeholder="Contanos en qué podemos ayudarte…"></textarea>
            </div>
          </div>

          <div style="margin-top:24px;display:flex;align-items:center;gap:20px;flex-wrap:wrap">
            <button type="submit" id="submitBtn" class="btn btn-primary btn-lg"
              style="flex:1;min-width:160px;justify-content:center">
              Enviar mensaje →
            </button>
            <p style="font-size:.78rem;color:var(--grey);max-width:220px;line-height:1.5">
              <i class="ph ph-lock"></i> Tus datos son confidenciales y no se comparten con terceros.
            </p>
          </div>
          <p id="formError" style="display:none;margin-top:16px;color:#c0392b;font-size:.88rem"></p>
        </form>

        <!-- Success state -->
        <div id="formSuccess" class="form-success">
          <div class="icon"><i class="ph ph-check-circle"></i></div>
          <h3>¡Mensaje enviado!</h3>
          <p>Gracias por contactarnos. Uno de nuestros asesores se comunicará con vos en breve.</p>
          <a href="https://wa.me/59899364330?text=Hola!%20Acabo%20de%20enviar%20un%20formulario%20en%20la%20web"
            target="_blank" class="btn btn-primary" style="margin-top:20px">
            <i class="ph ph-whatsapp-logo"></i> También podés escribirnos por WhatsApp
          </a>
        </div>
      </div>

    </div>
  </div>

  <!-- MAP -->
  <div class="container" style="padding-bottom:80px">
    <div class="animate-on-scroll">
      <div class="section-label" style="margin-bottom:16px">Ubicación</div>
      <h2 style="font-size:1.8rem;color:var(--blue);margin-bottom:24px">Cómo llegar</h2>
    </div>
    <div class="map-wrapper animate-on-scroll delay-1">
      <iframe
        src="https://www.google.com/maps/embed?pb=!1m18!1m12!1m3!1d3369.5!2d-57.035!3d-33.537!2m3!1f0!2f0!3f0!3m2!1i1024!2i768!4f13.1!3m3!1m2!1s0x0%3A0x0!2sTrinidad%2C+Flores%2C+Uruguay!5e0!3m2!1ses!2suy!4v1234567890"
        title="Cuevas Automóviles – Inés Duran 1181, Trinidad, Flores, Uruguay" allowfullscreen="" loading="lazy"
        referrerpolicy="no-referrer-when-downgrade">
      </iframe>
    </div>
    <div style="margin-top:20px;display:flex;gap:16px;flex-wrap:wrap">
      <a href="https://maps.google.com/?q=In%C3%A9s+Duran+1181+Trinidad+Flores+Uruguay" target="_blank"
        class="btn btn-secondary">
        <i class="ph ph-map-pin"></i> Abrir en Google Maps
      </a>
      <a href="https://wa.me/59899364330?text=Hola!%20¿C%C3%B3mo%20llego%20a%20su%20local%20en%20In%C3%A9s%20Duran%201181%2C%20Trinidad?"
        target="_blank" class="btn btn-ghost">
        <i class="ph ph-whatsapp-logo"></i> Pedir indicaciones por WhatsApp
      </a>
    </div>
  </div>

<script define:vars={{ cmsApiBaseUrl, tenantSlug }}>
  window.__CUEVAS_CMS_API_BASE__ = cmsApiBaseUrl;
  window.__CUEVAS_TENANT_SLUG__ = tenantSlug;
</script>
<script src="/js/inventory-api.js" is:inline></script>

</Layout>
