---
import Navbar from '../components/Navbar.astro';
import Footer from '../components/Footer.astro';
import WhatsappFloat from '../components/WhatsappFloat.astro';
import '../styles/styles.css';

interface Props {
  title: string;
  description?: string;
  navClass?: string;
  activeLink?: string;
}
const { title, description = 'Cuevas Automóviles, concesionaria en Trinidad, Uruguay.', navClass = 'solid', activeLink = '' } = Astro.props;
---
<!doctype html>
<html lang="es">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>{title}</title>
  <meta name="description" content={description}>

  <!-- Favicon -->
  <link rel="icon" href="/favicon.ico" sizes="any">
  <link rel="icon" href="/favicon.png" type="image/png">
  <link rel="apple-touch-icon" href="/favicon.png">

  <!-- Open Graph / Google -->
  <meta property="og:type" content="website">
  <meta property="og:site_name" content="Cuevas Automóviles">
  <meta property="og:title" content={title}>
  <meta property="og:description" content={description}>
  <meta property="og:image" content="https://cuevasautomoviles.com/images/favicon-square.png">
  <meta property="og:image:alt" content="Cuevas Automóviles - Concesionaria Trinidad, Uruguay">
  <meta property="og:locale" content="es_UY">

  <!-- Twitter Card -->
  <meta name="twitter:card" content="summary">
  <meta name="twitter:title" content={title}>
  <meta name="twitter:description" content={description}>
  <meta name="twitter:image" content="https://cuevasautomoviles.com/images/favicon-square.png">

  <!-- Schema.org logo para Google -->
  <script type="application/ld+json" is:inline>
  {
    "@context": "https://schema.org",
    "@type": "AutoDealer",
    "name": "Cuevas Automóviles",
    "url": "https://cuevasautomoviles.com",
    "logo": "https://cuevasautomoviles.com/images/favicon-square.png",
    "image": "https://cuevasautomoviles.com/images/favicon-square.png",
    "description": "Concesionaria oficial en Trinidad, Flores, Uruguay. Más de 36 años vendiendo autos nuevos y usados.",
    "telephone": "+59846343775",
    "address": {
      "@type": "PostalAddress",
      "streetAddress": "Inés Duran 1181",
      "addressLocality": "Trinidad",
      "addressRegion": "Flores",
      "addressCountry": "UY"
    }
  }
  </script>

  <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/@phosphor-icons/web@2.1.1/src/regular/style.css">
</head>
<body>
  <Navbar navClass={navClass} activeLink={activeLink} />
  <slot />
  <Footer />
  <WhatsappFloat />
  <script src="/js/main.js" is:inline></script>
</body>
</html>
